# Backup VPS2 Hetzner — variaveis de ambiente.
# Copie pra `.env` (NUNCA commitar — esta no .gitignore).
# Em producao, cadastre estas vars no painel do app no Coolify.

# -----------------------------------------------------------------------------
# Alvos pra dump
# -----------------------------------------------------------------------------
# Lista separada por virgula, formato `apelido:filter:db:user`
# apelido = nome curto no dump (ex.: zitadel)
# filter  = `docker ps --filter name=<filter>` (ex.: zitadel-db)
# db      = nome da database (ex.: zitadel)
# user    = role com permissao de dump (ex.: postgres)
TARGETS=zitadel:zitadel-db:zitadel:postgres,coolify:coolify-db:coolify:coolify

# -----------------------------------------------------------------------------
# Armazenamento local + retencao
# -----------------------------------------------------------------------------
BACKUP_RETENCAO=30

# -----------------------------------------------------------------------------
# Copia offsite via rclone (Backblaze B2)
# -----------------------------------------------------------------------------
# Bucket DEDICADO da VPS2 (separado do MaisControl pra blast radius).
RCLONE_REMOTE=b2:maiscontrol-vps2-backup

# Credenciais do remote via env (alternativa ao rclone.conf).
# Application Key com permissao SO no bucket vps2-backups.
RCLONE_CONFIG_B2_ACCOUNT=SEU_KEY_ID_B2
RCLONE_CONFIG_B2_KEY=SUA_APPLICATION_KEY_B2

# -----------------------------------------------------------------------------
# Alerta Telegram
# -----------------------------------------------------------------------------
# Reusa o bot+chat do control-bkp (VPS1) — mesmo canal recebe sucesso/falha
# das 2 VPS. Eh facil distinguir pelo prefixo da mensagem (MaisControl/VPS2).
TELEGRAM_BOT_TOKEN=123456:ABC-TOKEN-DO-BOT
TELEGRAM_CHAT_ID=000000000
